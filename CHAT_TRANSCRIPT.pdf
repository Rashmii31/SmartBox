 length = models.DecimalField(max_digits=10, decimal_places=2, help_text="Internal length in cm")
 width = models.DecimalField(max_digits=10, decimal_places=2, help_text="Internal width in cm")
 height = models.DecimalField(max_digits=10, decimal_places=2, help_text="Internal height in cm")
 max_weight_capacity = models.DecimalField(max_digits=10, decimal_places=2, help_text="Max weight in kg")
 cost = models.DecimalField(max_digits=10, decimal_places=2, help_text="Cost of the box")

 class Meta:
  verbose_name_plural = "Boxes"
  ordering = ['cost']

 @property
 def volume(self):
  return self.length * self.width * self.height

class Order(models.Model):
 created_at = models.DateTimeField(auto_now_add=True)
 assigned_box = models.ForeignKey(Box, on_delete=models.SET_NULL, null=True, blank=True)

class OrderItem(models.Model):
 order = models.ForeignKey(Order, on_delete=models.CASCADE, related_name='items')
 product = models.ForeignKey(Product, on_delete=models.PROTECT)
 quantity = models.PositiveIntegerField(default=1)</code></pre>

 <h2>Section 2: Box-Selection Algorithm (Service Layer)</h2>
 <p>The selection pipeline implements a 3-tier heuristic matching logic. It checks constraints linearly, ensuring maximum runtime efficiency before picking the most cost-effective match:</p>
 <ol>
  <li><strong>Weight Constraint:</strong> Total item load &le; Box Max Weight.</li>
  <li><strong>Volumetric Constraint:</strong> Total items physical envelope &le; Box Volume.</li>
  <li><strong>Dimension Uniformity:</strong> The single largest dimension of any standalone item must fit inside the absolute longest axis of the candidate packaging box.</li>
 </ol>

 <h3>File: <code>box_selector/services.py</code></h3>
 <pre><code>from decimal import Decimal
from .models import Box

def recommend_and_assign_box(order):
 items = order.items.select_related('product').all()
 if not items:
  return None

 total_weight = Decimal('0.00')
 total_volume = Decimal('0.00')
 max_single_dimension = Decimal('0.00')

 for item in items:
  prod = item.product
  qty = Decimal(str(item.quantity))
  total_weight += prod.weight * qty
  total_volume += prod.volume * qty
  item_max_dim = max(prod.length, prod.width, prod.height)
  if item_max_dim > max_single_dimension:
   max_single_dimension = item_max_dim

 candidate_boxes = Box.objects.filter(max_weight_capacity__gte=total_weight)
 for box in candidate_boxes:
  if box.volume < total_volume:
   continue
  box_max_dim = max(box.length, box.width, box.height)
  if max_single_dimension > box_max_dim:
   continue

  order.assigned_box = box
  order.save(update_fields=['assigned_box'])
  return box

 return None</code></pre>

 <h2>Section 3: REST API Implementation</h2>
 <p>Using Django Rest Framework (DRF), this endpoint accepts structured payload sequences, coordinates the atomic transaction lifecycles, runs evaluations, and serializes final execution logs safely.</p>
 
 <h3>File: <code>box_selector/serializers.py</code></h3>
 <pre><code>from rest_framework import serializers

class OrderItemInputSerializer(serializers.Serializer):
 product_id = serializers.IntegerField()
 quantity = serializers.IntegerField(min_value=1)

class BoxRecommendationRequestSerializer(serializers.Serializer):
 items = OrderItemInputSerializer(many=True, allow_empty=False)</code></pre>

 <h3>File: <code>box_selector/views.py</code></h3>
 <pre><code>from django.db import transaction
from rest_framework.views import APIView
from rest_framework.response import Response
from rest_framework import status
from .models import Product, Order, OrderItem
from .serializers import BoxRecommendationRequestSerializer
from .services import recommend_and_assign_box

class BoxRecommendationView(APIView):
 def post(self, request, *args, **kwargs):
  serializer = BoxRecommendationRequestSerializer(data=request.data)
  if not serializer.is_valid():
   return Response(serializer.errors, status=status.HTTP_400_BAD_REQUEST)

  validated_items = serializer.validated_data['items']
  try:
   with transaction.atomic():
    order = Order.objects.create()
    for item_data in validated_items:
     try:
      product = Product.objects.get(id=item_data['product_id'])
     except Product.DoesNotExist:
      return Response({"error": f"Product ID not found."}, status=status.HTTP_404_NOT_FOUND)

     OrderItem.objects.create(order=order, product=product, quantity=item_data['quantity'])

    recommended_box = recommend_and_assign_box(order)

    if recommended_box:
     return Response({
      "order_id": order.id,
      "status": "Box Assigned Successfully",
      "recommended_box": {
       "id": recommended_box.id,
       "name": recommended_box.name,
       "cost": str(recommended_box.cost)
      }
     }, status=status.HTTP_200_OK)
    else:
     return Response({
      "order_id": order.id,
      "status": "Unassignable",
      "message": "No warehouse boxes fulfill the requirements."
     }, status=status.HTTP_422_UNPROCESSABLE_ENTITY)
  except Exception as e:
   return Response({"error": str(e)}, status=status.HTTP_500_INTERNAL_SERVER_ERROR)</code></pre>

 <h2>Section 4: Comprehensive Test Suite</h2>
 <p>The code uses isolated mock test conditions inside Django's native test framework to confirm strict physical boundary checks.</p>

 <h3>File: <code>box_selector/tests.py</code></h3>
 <pre><code>from django.urls import reverse
from rest_framework.test import APITestCase
from rest_framework import status
from .models import Product, Box

class BoxSelectionAPITests(APITestCase):
 def setUp(self):
  self.small_box = Box.objects.create(name="Small Box", length=10, width=10, height=10, max_weight_capacity=5, cost=2.00)
  self.heavy_box = Box.objects.create(name="Heavy Duty Box", length=12, width=12, height=12, max_weight_capacity=50, cost=8.00)
  self.long_box = Box.objects.create(name="Long Tube Box", length=40, width=5, height=5, max_weight_capacity=10, cost=5.00)

  self.light_item = Product.objects.create(name="Feather", length=2, width=2, height=2, weight=0.1)
  self.dense_item = Product.objects.create(name="Lead Weight", length=2, width=2, height=2, weight=25.0)
  self.long_item = Product.objects.create(name="Poster", length=35, width=2, height=2, weight=0.5)
  self.oversized_item = Product.objects.create(name="Giant Couch", length=100, width=100, height=100, weight=200)

  self.url = reverse('recommend-box')

 def test_happy_path_picks_cheapest(self):
  data = {"items": [{"product_id": self.light_item.id, "quantity": 1}]}
  res = self.client.post(self.url, data, format='json')
  self.assertEqual(res.status_code, status.HTTP_200_OK)
  self.assertEqual(res.data['recommended_box']['name'], "Small Box")

 def test_weight_constraint_forces_heavy_box(self):
  data = {"items": [{"product_id": self.dense_item.id, "quantity": 1}]}
  res = self.client.post(self.url, data, format='json')
  self.assertEqual(res.status_code, status.HTTP_200_OK)
  self.assertEqual(res.data['recommended_box']['name'], "Heavy Duty Box")

 def test_dimension_constraint_forces_long_box(self):
  data = {"items": [{"product_id": self.long_item.id, "quantity": 1}]}
  res = self.client.post(self.url, data, format='json')
  self.assertEqual(res.status_code, status.HTTP_200_OK)
  self.assertEqual(res.data['recommended_box']['name'], "Long Tube Box")

 def test_no_box_fits_returns_422(self):
  data = {"items": [{"product_id": self.oversized_item.id, "quantity": 1}]}
  res = self.client.post(self.url, data, format='json')
  self.assertEqual(res.status_code, status.HTTP_422_UNPROCESSABLE_ENTITY)</code></pre>

